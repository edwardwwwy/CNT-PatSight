# Python, tests, coverage, and build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
coverage.xml
htmlcov/
build/
dist/
node_modules/

# Local environments and credentials
.venv/
venv/
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
service-account*.json

# Local tools, editors, and assistant workspace metadata
.tools/
.agents/
.vscode/
.idea/
AGENTS.md
skills/

# OS and temporary files
.DS_Store
Thumbs.db
Desktop.ini
tmp/
temp/
*.tmp
*.log
~$*

# Generated deliverables are local until deliberately curated for reports/.
/output/
/exports/

# Local model weights and runtimes are never repository content.
/models/**

# Generic database and runtime state. Public datasets should use reviewed,
# versioned CSV/Parquet releases rather than mutable database files.
*.sqlite
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.db
*.db-shm
*.db-wal

# Confidential or internal R&D data. Keep only the policy file.
/data/internal/**
!/data/internal/README.md
/data/private/
/data/company/

# Downloaded papers, patents, supplementary files, raw API responses, complete
# metadata, and faithful full-text derivatives stay local. README files may
# document how to obtain or rebuild them without redistributing the content.
/data/raw/**
!/data/raw/**/
!/data/raw/**/README.md

# Interim, derived, review-queue, and delivery data are local by default.
# Approved examples belong in data/samples/, not in these runtime directories.
/data/interim/**
!/data/interim/**/
!/data/interim/**/README.md
/data/interim/legacy_audit/
/data/derived/
/data/processed/**
!/data/processed/**/
!/data/processed/templates/**
/data/review/extraction/

# Sample data never includes source documents or bundled archives.
/data/samples/**/*.pdf
/data/samples/**/*.docx
/data/samples/**/*.zip

# Generated page renders and OCR/debug assets outside the standard runtime dirs.
/rendered_*.png
/page_*.png
