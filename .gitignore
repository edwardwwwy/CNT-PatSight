# Python, tests, coverage, and build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
coverage.xml
htmlcov/
build/
dist/
node_modules/

# Local environments and credentials
.venv/
venv/
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
service-account*.json

# Local tools, editors, and assistant workspace metadata
.tools/
.agents/
.vscode/
.idea/
AGENTS.md
skills/

# OS and temporary files
.DS_Store
Thumbs.db
Desktop.ini
tmp/
temp/
*.tmp
*.log
~$*
/runs/
/cache/
/archive/
*.confidential.*

# Generated deliverables are local until deliberately curated for reports/.
/output/
/outputs/
/exports/

# Company-specific report builders may contain private experiment metadata.
/scripts/reporting/build_248_experiment_eight_tables_pdf.py

# Local model weights and runtimes are never repository content.
/models/**

# Generic database and runtime state. Public datasets should use reviewed,
# versioned CSV/Parquet releases rather than mutable database files.
*.sqlite
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.db
*.db-shm
*.db-wal

# data/ follows the raw/interim/processed/benchmark lifecycle. Private,
# licensed, generated, and mutable data stay local; policy files and approved
# public benchmark assets remain trackable.
/data/raw/**
!/data/raw/**/
!/data/raw/**/README.md

/data/interim/**
!/data/interim/**/
!/data/interim/**/README.md
!/data/interim/**/CANDIDATE_PIPELINE.md

/data/processed/**
!/data/processed/**/
!/data/processed/**/README.md

/data/benchmark/**
!/data/benchmark/**/
!/data/benchmark/**/README.md
!/data/benchmark/samples/templates/**
!/data/benchmark/samples/public/**
!/data/benchmark/results/screening_benchmark/**

/data/company/**
!/data/company/README.md
/data/private/

# Public sample data never includes source documents or bundled archives.
/data/benchmark/samples/public/**/*.pdf
/data/benchmark/samples/public/**/*.docx
/data/benchmark/samples/public/**/*.zip

# Generated page renders and OCR/debug assets outside the standard runtime dirs.
/rendered_*.png
/page_*.png
