{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CNT-LitSight experiment run planning contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "input_content_hash",
    "runs",
    "shared_conditions",
    "planning_notes"
  ],
  "properties": {
    "schema_version": {"const": "run_plan_v1"},
    "source_id": {"type": "string", "minLength": 1},
    "input_content_hash": {"type": "string", "minLength": 16},
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/run"}
    },
    "shared_conditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reactor_type": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        },
        "reactor_setup_summary": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        },
        "catalyst_loading_mass_g": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        },
        "temperature_setpoint_C": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        },
        "heating_rate_C_min": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        },
        "holding_time_min": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        },
        "carbon_source": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        },
        "carbon_source_flow_original": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        },
        "cooling_condition": {
          "oneOf": [{"$ref": "#/$defs/shared_condition"}, {"type": "null"}]
        }
      }
    },
    "planning_notes": {"type": "string"}
  },
  "$defs": {
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planned_run_id",
        "catalyst_label",
        "aliases",
        "role",
        "catalyst_evidence_span_ids",
        "result_evidence_span_ids"
      ],
      "properties": {
        "planned_run_id": {
          "type": "string",
          "pattern": "^PLAN_RUN_[0-9]{3}$"
        },
        "catalyst_label": {"type": "string", "minLength": 1},
        "aliases": {
          "type": "array",
          "maxItems": 5,
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "role": {
          "enum": ["experimental", "negative_control", "positive_control"]
        },
        "catalyst_evidence_span_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "result_evidence_span_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string"}
        }
      }
    },
    "shared_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_raw",
        "value_normalized",
        "unit",
        "evidence_span_id"
      ],
      "properties": {
        "value_raw": {
          "type": ["string", "number", "boolean"]
        },
        "value_normalized": {
          "type": ["string", "number", "boolean", "null"]
        },
        "unit": {"type": ["string", "null"]},
        "evidence_span_id": {"type": "string"}
      }
    }
  }
}
