{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CNT-PatSight extraction staging contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "source_title",
    "input_content_hash",
    "extraction_scope",
    "run_candidates",
    "catalyst_candidates",
    "process_stage_candidates",
    "product_candidates",
    "cost_scale_candidates",
    "source_observations",
    "evidence_claims",
    "review_issues",
    "extraction_notes"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "0.1"},
    "source_id": {"type": "string", "minLength": 1},
    "source_title": {"type": "string", "minLength": 1},
    "input_content_hash": {"type": "string", "minLength": 16},
    "extraction_scope": {"type": "string", "const": "candidate_spans_only"},
    "run_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_run_id", "run_label", "run_summary", "run_split_basis", "relevance_class", "confidence", "evidence_span_ids"],
        "properties": {
          "candidate_run_id": {"type": "string", "pattern": "^RUN_CAND_[0-9]{3}$"},
          "run_label": {"type": "string", "minLength": 1},
          "run_summary": {"type": "string"},
          "run_split_basis": {"type": "string", "minLength": 1},
          "relevance_class": {"type": "string", "enum": ["high", "medium", "low"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence_span_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^SPAN_.+$"}}
        }
      }
    },
    "catalyst_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_catalyst_id", "candidate_run_id", "confidence"],
        "properties": {
          "candidate_catalyst_id": {"type": "string", "pattern": "^CAT_CAND_[0-9]{3}$"},
          "candidate_run_id": {"type": "string", "pattern": "^RUN_CAND_[0-9]{3}$"},
          "evidence_span_ids": {"type": "array", "items": {"type": "string", "pattern": "^SPAN_.+$"}},
          "catalyst_label": {"type": ["string", "null"]},
          "active_metals": {"type": "array", "items": {"type": "string"}},
          "support_material": {"type": ["string", "null"]},
          "promoter": {"type": ["string", "null"]},
          "metal_ratio_original": {"type": ["string", "null"]},
          "precursor_summary": {"type": ["string", "null"]},
          "preparation_method": {"type": ["string", "null"]},
          "preparation_modifier": {"type": ["string", "null"], "enum": ["acid_washing", "support_acidification", "catalyst_acidification", "acid_complexing", "alkali_assisted", "surfactant_assisted", "chelating_agent", "not_applicable", "other", null]},
          "preparation_detail": {"type": ["string", "null"]},
          "drying_condition": {"type": ["string", "null"]},
          "calcination_condition": {"type": ["string", "null"]},
          "reduction_condition": {"type": ["string", "null"]},
          "activation_condition": {"type": ["string", "null"]},
          "catalyst_particle_size_range_nm": {"type": ["string", "null"]},
          "BET_surface_area_m2_g": {"type": ["number", "null"]},
          "phase_or_state_summary": {"type": ["string", "null"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "process_stage_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_stage_id", "candidate_run_id", "stage_order", "stage_type", "confidence"],
        "properties": {
          "candidate_stage_id": {"type": "string", "pattern": "^STAGE_CAND_[0-9]{3}$"},
          "candidate_run_id": {"type": "string", "pattern": "^RUN_CAND_[0-9]{3}$"},
          "evidence_span_ids": {"type": "array", "items": {"type": "string", "pattern": "^SPAN_.+$"}},
          "stage_order": {"type": "integer", "minimum": 1},
          "stage_type": {"type": "string", "enum": ["drying", "calcination", "thermal_decomposition", "reduction", "activation", "heating", "cnt_growth", "cooling", "purification", "other"]},
          "reactor_type": {"type": ["string", "null"]},
          "scale_level": {"type": ["string", "null"]},
          "reactor_material": {"type": ["string", "null"]},
          "reactor_size_summary": {"type": ["string", "null"]},
          "catalyst_loading_mass_g": {"type": ["number", "null"]},
          "temperature_setpoint_C": {"type": ["number", "null"]},
          "temperature_range_reported_C": {"type": ["string", "null"]},
          "holding_time_min": {"type": ["number", "null"]},
          "pressure_original": {"type": ["string", "null"]},
          "pressure_kPa": {"type": ["number", "null"]},
          "carbon_source": {"type": ["string", "null"]},
          "carbon_source_flow_original": {"type": ["string", "null"]},
          "carbon_source_flow_sccm": {"type": ["number", "null"]},
          "reducing_gas": {"type": ["string", "null"]},
          "reducing_gas_flow_original": {"type": ["string", "null"]},
          "reducing_gas_flow_sccm": {"type": ["number", "null"]},
          "inert_gas": {"type": ["string", "null"]},
          "inert_gas_flow_original": {"type": ["string", "null"]},
          "inert_gas_flow_sccm": {"type": ["number", "null"]},
          "cofeed_or_reactive_gas": {"type": ["string", "null"]},
          "cofeed_flow_original": {"type": ["string", "null"]},
          "cofeed_flow_sccm": {"type": ["number", "null"]},
          "total_flow_original": {"type": ["string", "null"]},
          "total_flow_sccm": {"type": ["number", "null"]},
          "gas_composition_summary": {"type": ["string", "null"]},
          "GHSV_or_residence_time": {"type": ["string", "null"]},
          "process_note": {"type": ["string", "null"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "product_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_product_id", "candidate_run_id", "confidence"],
        "properties": {
          "candidate_product_id": {"type": "string", "pattern": "^PROD_CAND_[0-9]{3}$"},
          "candidate_run_id": {"type": "string", "pattern": "^RUN_CAND_[0-9]{3}$"},
          "evidence_span_ids": {"type": "array", "items": {"type": "string", "pattern": "^SPAN_.+$"}},
          "primary_yield_metric": {"type": ["string", "null"], "enum": ["carbon_weight_gain_percent", "CNT_yield_per_catalyst", "CNT_productivity", "carbon_conversion_to_solid", "methane_conversion", "CNT_array_height", "reported_yield_other", null]},
          "yield_original": {"type": ["string", "null"]},
          "yield_definition_original": {"type": ["string", "null"]},
          "yield_calculation_method": {"type": ["string", "null"]},
          "yield_value_standardized": {"type": ["number", "null"]},
          "yield_unit_standardized": {"type": ["string", "null"]},
          "CNT_yield_per_catalyst_g_gcat": {"type": ["number", "null"]},
          "CNT_productivity_g_gcat_h": {"type": ["number", "null"]},
          "carbon_source_conversion_percent": {"type": ["number", "null"]},
          "carbon_conversion_to_solid_percent": {"type": ["number", "null"]},
          "CNT_type_reported": {"type": ["string", "null"]},
          "CNT_type_confirmed": {"type": ["string", "null"]},
          "product_mixture_summary": {"type": ["string", "null"]},
          "CNT_type_evidence": {"type": ["string", "null"]},
          "outer_diameter_range_nm": {"type": ["string", "null"]},
          "wall_number_summary": {"type": ["string", "null"]},
          "morphology": {"type": ["string", "null"]},
          "Raman_ratio_type": {"type": ["string", "null"], "enum": ["ID/IG", "IG/ID", null]},
          "Raman_ratio_value": {"type": ["number", "null"]},
          "TGA_carbon_content_wt_percent": {"type": ["number", "null"]},
          "purified_product_purity_wt_percent": {"type": ["number", "null"]},
          "purity_basis": {"type": ["string", "null"], "enum": ["as_synthesized_TGA_carbon_content", "post_purification_product_purity", "ash_or_residue_basis", "author_unspecified", "not_reported", null]},
          "amorphous_carbon_level": {"type": ["string", "null"]},
          "characterization_methods": {"type": "array", "items": {"type": "string"}},
          "post_treatment_or_purification": {"type": ["string", "null"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "cost_scale_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_cost_scale_id", "candidate_run_id", "quantitative_cost_reported", "confidence"],
        "properties": {
          "candidate_cost_scale_id": {"type": "string", "pattern": "^SCALE_CAND_[0-9]{3}$"},
          "candidate_run_id": {"type": "string", "pattern": "^RUN_CAND_[0-9]{3}$"},
          "evidence_span_ids": {"type": "array", "items": {"type": "string", "pattern": "^SPAN_.+$"}},
          "scale_level_demonstrated": {"type": ["string", "null"]},
          "scale_level_claimed": {"type": ["string", "null"]},
          "scale_evidence_summary": {"type": ["string", "null"]},
          "reactor_capacity_or_throughput": {"type": ["string", "null"]},
          "continuous_operation_time_h": {"type": ["number", "null"]},
          "catalyst_lifetime_or_reuse": {"type": ["string", "null"]},
          "batch_stability": {"type": ["string", "null"]},
          "scale_up_issue": {"type": ["string", "null"]},
          "quantitative_cost_reported": {"type": "boolean"},
          "quantitative_cost_summary": {"type": ["string", "null"]},
          "cost_driver_summary": {"type": ["string", "null"]},
          "safety_risk": {"type": ["string", "null"]},
          "emission_or_waste": {"type": ["string", "null"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "source_observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_observation_id", "observation_type", "summary", "evidence_span_ids", "value_status", "confidence"],
        "properties": {
          "candidate_observation_id": {"type": "string", "pattern": "^OBS_CAND_[0-9]{3}$"},
          "observation_type": {"type": "string", "enum": ["mechanism", "failure", "preparation_hint", "temperature_effect", "scale_signal", "safety_environment", "transferable_route", "other"]},
          "summary": {"type": "string", "minLength": 1},
          "evidence_span_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^SPAN_.+$"}},
          "value_status": {"type": "string", "enum": ["reported", "calculated", "inferred"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "evidence_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "target_type", "target_id", "target_fields", "span_ids", "evidence_quote", "value_status", "confidence", "notes"],
        "properties": {
          "claim_id": {"type": "string", "pattern": "^CLM_[0-9]{3}$"},
          "target_type": {"type": "string", "enum": ["run", "catalyst", "process_stage", "product", "cost_scale", "source_observation", "review_issue"]},
          "target_id": {"type": "string", "minLength": 1},
          "target_fields": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "span_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^SPAN_.+$"}},
          "evidence_quote": {"type": "string", "minLength": 1},
          "value_status": {"type": "string", "enum": ["reported", "calculated", "inferred"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "notes": {"type": "string"}
        }
      }
    },
    "review_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_issue_id", "candidate_run_id", "issue_type", "target_type", "target_id", "target_field", "issue_summary", "conflicting_values", "evidence_span_ids", "severity", "review_status"],
        "properties": {
          "candidate_issue_id": {"type": "string", "pattern": "^ISSUE_CAND_[0-9]{3}$"},
          "candidate_run_id": {"type": ["string", "null"]},
          "issue_type": {"type": "string", "enum": ["source_conflict", "definition_ambiguity", "run_split_uncertainty", "CNT_type_uncertainty", "calculation_check", "critical_data_gap", "quality_warning", "schema_mapping_question"]},
          "target_type": {"type": "string", "enum": ["run", "catalyst", "process_stage", "product", "cost_scale", "source"]},
          "target_id": {"type": ["string", "null"]},
          "target_field": {"type": "string"},
          "issue_summary": {"type": "string", "minLength": 1},
          "conflicting_values": {"type": "array", "items": {"type": "string"}},
          "evidence_span_ids": {"type": "array", "items": {"type": "string", "pattern": "^SPAN_.+$"}},
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "review_status": {"type": "string", "const": "open"}
        }
      }
    },
    "extraction_notes": {"type": "string"}
  }
}
