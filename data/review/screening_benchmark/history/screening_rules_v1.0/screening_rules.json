{
  "screening_rule_version": "v1.0",
  "dedup_rule_version": "v1.0",
  "screening": {
    "tier_a_topic_min": 7.0,
    "tier_a_evidence_min": 3.0,
    "tier_b_topic_min": 6.0
  },
  "dedup": {
    "auto_merge_threshold": 0.97,
    "review_threshold": 0.92,
    "title_min_length": 30,
    "year_tolerance": 1,
    "require_document_type_compatibility": true,
    "require_first_author_or_venue_match": true,
    "different_nonempty_doi_action": "doi_conflict_review"
  },
  "policy": {
    "automatic_formal_extract": false,
    "metadata_candidate_tiers": ["A", "B", "M"],
    "fulltext_required_before_candidate_extract": true
  }
}
